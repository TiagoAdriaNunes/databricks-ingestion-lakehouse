DATABRICKS_HOST=dbc-YOUR-HOST-NAME.cloud.databricks.com
DATABRICKS_TOKEN=dapieYOUR-TOKEN-HERE
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/YOUR-WAREHOUSE-ID
DATABRICKS_CATALOG=workspace

# Schema names for each medallion layer
DATABRICKS_SCHEMA=bronze
DATABRICKS_BRONZE_SCHEMA=bronze
DATABRICKS_SILVER_SCHEMA=silver
DATABRICKS_GOLD_SCHEMA=gold

# Volume name (lives inside DATABRICKS_SCHEMA) where raw Parquet files are stored
DATABRICKS_VOLUME=raw_files

# Last month of data ingested into the Volume (YYYY-MM). Update when new files are uploaded.
LAST_INGESTED_MONTH=2026-01
